<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="jeo_ano_ba.StartPage"
             BackgroundColor="#0D0B1E">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="JEO ANO BA"
                   FontSize="34"
                   FontAttributes="Bold"
                   TextColor="#FF9800"
                   HorizontalOptions="Center" />

            <Label Text="How many players? (1-4)"
                   TextColor="White"
                   HorizontalOptions="Center" />

            <Picker x:Name="PlayerCountPicker"
                    SelectedIndexChanged="OnPlayerCountChanged"
                    HorizontalOptions="Center"
                    WidthRequest="120"
                    TextColor="White">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>1</x:String>
                        <x:String>2</x:String>
                        <x:String>3</x:String>
                        <x:String>4</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>

            <VerticalStackLayout x:Name="PlayerNamesStack" Spacing="8" />

            <BoxView HeightRequest="1" Color="#333333" Margin="0,10" />

            <Button Text="🌐 API GAME (Open Trivia DB)"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    FontAttributes="Bold"
                    Clicked="OnApiGameClicked" />

            <Button Text="🎨 CUSTOM GAME (Local Question Bank)"
                    BackgroundColor="#FF9800"
                    TextColor="Black"
                    FontAttributes="Bold"
                    Clicked="OnCustomGameClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>