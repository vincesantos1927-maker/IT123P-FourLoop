<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="jeo_ano_ba.StartPage"
             BackgroundColor="#0D0B1E">

    <ScrollView>
        <VerticalStackLayout Padding="30" Spacing="20" VerticalOptions="Center">

            <Label Text="JEO ANO BA"
                   FontSize="34"
                   FontAttributes="Bold"
                   TextColor="#FF9800"
                   HorizontalOptions="Center" />

            <Button Text="🌐 API GAME (Open Trivia DB)"
                    BackgroundColor="#2196F3"
                    TextColor="White"
                    FontAttributes="Bold"
                    Clicked="OnApiGameClicked" />

            <Button Text="🎨 CUSTOM GAME (Local Question Bank)"
                    BackgroundColor="#FF9800"
                    TextColor="Black"
                    FontAttributes="Bold"
                    Clicked="OnCustomGameClicked" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>