<?xml version="1.0" encoding="utf-8" ?>

<ContentPage
    x:Class="jeo_ano_ba.Views.WinnersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:model="clr-namespace:jeo_ano_ba.Models"
    Shell.NavBarIsVisible="False">

    <Grid>

        <!-- Background -->
        <Image
            Source="bg3.png"
            Aspect="AspectFill"/>

        <Grid Padding="24,55,24,25">

            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ScrollView Grid.Row="0">

                <VerticalStackLayout
                    Padding="0"
                    Spacing="20">

                    <!-- HEADER -->

                    <VerticalStackLayout
                Grid.Row="0"
                HorizontalOptions="Center"
                Spacing="4">

                        <Label
                    Text="LEADERBOARDS"
                    FontSize="30"
                    FontAttributes="Bold"
                    TextColor="#FFD700"
                    HorizontalOptions="Center"/>

                        <Border
                    WidthRequest="160"
                    HeightRequest="2"
                    StrokeThickness="0">

                            <Border.Background>
                                <LinearGradientBrush
                            StartPoint="0,0"
                            EndPoint="1,0">

                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#FFD700" Offset=".5"/>
                                    <GradientStop Color="Transparent" Offset="1"/>

                                </LinearGradientBrush>

                            </Border.Background>

                        </Border>

                        <Label
                    Text="Top 10 Players"
                    FontSize="14"
                    CharacterSpacing="2"
                    TextColor="White"
                    HorizontalOptions="Center"/>

                    </VerticalStackLayout>

                    <!-- ========================= -->
                    <!--        TOP PODIUM         -->
                    <!-- ========================= -->

                    <Grid
                Grid.Row="1"
                Margin="0,25,0,15"
                ColumnDefinitions="*,*,*"
                VerticalOptions="End">

                        <!-- SECOND -->

                        <VerticalStackLayout
                    Grid.Column="0"
                    HorizontalOptions="Center"
                    VerticalOptions="End"
                    Spacing="6">

                            <Border
                        WidthRequest="72"
                        HeightRequest="72"
                        BackgroundColor="#C9CED6"
                        Stroke="White"
                        StrokeThickness="2">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="36"/>
                                </Border.StrokeShape>

                                <Label
                            Text="🥈"
                            FontSize="32"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                            </Border>

                            <Label
                        x:Name="SecondName"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalTextAlignment="Center"/>

                            <Label
                        x:Name="SecondScore"
                        FontSize="15"
                        TextColor="#FFD700"
                        HorizontalTextAlignment="Center"/>

                            <Border
                        WidthRequest="90"
                        HeightRequest="95"
                        BackgroundColor="#42577B">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>

                                <Label
                            Text="2"
                            FontSize="45"
                            Opacity=".30"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                            </Border>

                        </VerticalStackLayout>

                        <!-- FIRST -->

                        <VerticalStackLayout
                    Grid.Column="1"
                    HorizontalOptions="Center"
                    VerticalOptions="End"
                    Spacing="8">

                            <Border
                        WidthRequest="92"
                        HeightRequest="92"
                        BackgroundColor="#FFD700">
                                
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="46"/>
                                </Border.StrokeShape>

                                <Border.Shadow>
                                    <Shadow
                                    Brush="#FFD700"
                                    Radius="22"
                                    Offset="0,10"
                                    Opacity="0.45"/>
                                </Border.Shadow>


                                <Label
                            Text="👑"
                            FontSize="44"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                            </Border>

                            <Label
                        x:Name="FirstName"
                        FontSize="20"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalTextAlignment="Center"/>

                            <Label
                        x:Name="FirstScore"
                        FontSize="18"
                        FontAttributes="Bold"
                        TextColor="#FFD700"
                        HorizontalTextAlignment="Center"/>

                            <Border
                        WidthRequest="100"
                        HeightRequest="125"
                        BackgroundColor="#5C79A5">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>

                                <Label
                            Text="1"
                            FontSize="60"
                            FontAttributes="Bold"
                            Opacity=".30"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                            </Border>

                        </VerticalStackLayout>

                        <!-- THIRD -->

                        <VerticalStackLayout
                    Grid.Column="2"
                    HorizontalOptions="Center"
                    VerticalOptions="End"
                    Spacing="6">

                            <Border
                        WidthRequest="72"
                        HeightRequest="72"
                        BackgroundColor="#C88652"
                        Stroke="White"
                        StrokeThickness="2">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="36"/>
                                </Border.StrokeShape>

                                <Label
                            Text="🥉"
                            FontSize="32"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                            </Border>

                            <Label
                        x:Name="ThirdName"
                        FontSize="16"
                        FontAttributes="Bold"
                        TextColor="White"
                        HorizontalTextAlignment="Center"/>

                            <Label
                        x:Name="ThirdScore"
                        FontSize="15"
                        TextColor="#FFD700"
                        HorizontalTextAlignment="Center"/>

                            <Border
                        WidthRequest="90"
                        HeightRequest="75"
                        BackgroundColor="#34455F">

                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="12"/>
                                </Border.StrokeShape>

                                <Label
                            Text="3"
                            FontSize="45"
                            Opacity=".30"
                            FontAttributes="Bold"
                            HorizontalOptions="Center"
                            VerticalOptions="Center"/>

                            </Border>

                        </VerticalStackLayout>

                    </Grid>

                    <!-- ========================= -->
                    <!-- Remaining Players -->
                    <!-- ========================= -->

                    <VerticalStackLayout
                Grid.Row="2"
                Margin="0,10,0,20"
                Spacing="10">

                        <Label
                    Text="OTHER PLAYERS"
                    FontSize="14"
                    FontAttributes="Bold"
                    CharacterSpacing="2"
                    TextColor="#FFD700"
                    HorizontalOptions="Center"/>

                        <CollectionView
                    x:Name="LeaderboardCollection"
                    SelectionMode="None">

                            <CollectionView.ItemTemplate>

                                <DataTemplate x:DataType="model:GameResultDb">

                                    <Border
                                Margin="0,0,0,12"
                                Padding="16"
                                BackgroundColor="#882F67A8"
                                Stroke="#FFD700"
                                StrokeThickness="0.5">

                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="18"/>
                                        </Border.StrokeShape>

                                        <Border.Shadow>
                                            <Shadow
                                        Brush="Black"
                                        Radius="14"
                                        Offset="0,6"
                                        Opacity="0.25"/>
                                        </Border.Shadow>

                                        <Grid
                                    ColumnDefinitions="55,*,Auto"
                                    ColumnSpacing="12">

                                            <!-- Medal -->

                                            <Border
                                        WidthRequest="46"
                                        HeightRequest="46"
                                        BackgroundColor="#1C3F68"
                                        Stroke="#FFD700">

                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="23"/>
                                                </Border.StrokeShape>

                                                <Label
                                            Text="🏅"
                                            FontSize="20"
                                            HorizontalOptions="Center"
                                            VerticalOptions="Center"/>

                                            </Border>

                                            <!-- Player Info -->

                                            <VerticalStackLayout
                                        Grid.Column="1"
                                        Spacing="2">

                                                <Label
                                            Text="{Binding PlayerName}"
                                            FontSize="18"
                                            FontAttributes="Bold"
                                            TextColor="White"/>

                                                <Label
                                            Text="{Binding GameName}"
                                            FontSize="13"
                                            TextColor="#D9E6FF"/>

                                                <Label
                                            Text="{Binding PlayedAt, StringFormat='Played {0:MMMM dd, yyyy}'}"
                                            FontSize="11"
                                            TextColor="#B8C8E8"/>

                                            </VerticalStackLayout>

                                            <!-- Score -->

                                            <VerticalStackLayout
                                        Grid.Column="2"
                                        HorizontalOptions="End"
                                        VerticalOptions="Center">

                                                <Label
                                            Text="SCORE"
                                            FontSize="10"
                                            TextColor="#FFD700"
                                            HorizontalOptions="End"/>

                                                <Label
                                            Text="{Binding Score}"
                                            FontSize="24"
                                            FontAttributes="Bold"
                                            TextColor="#FFD700"
                                            HorizontalOptions="End"/>

                                            </VerticalStackLayout>

                                        </Grid>

                                    </Border>

                                </DataTemplate>

                            </CollectionView.ItemTemplate>

                        </CollectionView>

                    </VerticalStackLayout>
                    
                </VerticalStackLayout>

            </ScrollView>

            <!-- ========================= -->
            <!-- Bottom Button -->
            <!-- ========================= -->

            <Grid
                Grid.Row="3"
                Padding="24,20"
                HorizontalOptions="Fill">

                <Border
                    HorizontalOptions="Fill"
                    BackgroundColor="#FFD700"
                    Stroke="#FFE082"
                    StrokeThickness="0.5"
                    Padding="18">

                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18"/>
                    </Border.StrokeShape>

                    <Border.Shadow>
                        <Shadow
                            Brush="Black"
                            Radius="18"
                            Offset="0,4"
                            Opacity="0.35"/>
                    </Border.Shadow>

                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="HomeTapped"/>
                    </Border.GestureRecognizers>

                    <Label
                        Text="Return to Main Menu"
                        FontSize="18"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        HorizontalTextAlignment="Center"
                        VerticalOptions="Center"
                        TextColor="#14253F"/>

                </Border>

            </Grid>

        </Grid>

    </Grid>

</ContentPage>