<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="jeo_ano_ba.MainPage"
             BackgroundColor="#0F0F2D">

    <Grid RowDefinitions="Auto, *, Auto" RowSpacing="15" ColumnSpacing="15">

        <!-- HEADER -->
        <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Padding="20,20,20,0">
            <Label Text="JEO! ANO BA?"
                   TextColor="#FFCC00"
                   FontSize="28"
                   FontAttributes="Bold"
                   VerticalOptions="Center"/>
            <Button Grid.Column="1"
                    Text="End Game"
                    Clicked="OnEndGameClicked"
                    BackgroundColor="#1E1E3F"
                    TextColor="White"
                    CornerRadius="20"
                    FontAttributes="Bold"
                    Padding="15,8"/>
        </Grid>

        <!-- BOARD -->
        <Grid Grid.Row="1" ColumnDefinitions="0, *" Padding="10,0">

            <VerticalStackLayout Grid.Column="0" Spacing="10" Padding="5" IsVisible="False">
                <Label Text="Games In Database:" TextColor="Gray" FontAttributes="Bold"/>
                <ListView x:Name="GamesListView" ItemSelected="OnGameSelected" BackgroundColor="#1E1E3F">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextCell Text="{Binding Name}" TextColor="White"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </VerticalStackLayout>

            <Grid x:Name="ProxyBoardGrid" Grid.Column="1" ColumnSpacing="4" RowSpacing="4"/>
        </Grid>

        <!-- GAMEPLAY MODAL -->
        <Grid x:Name="EvaluationModal" Grid.Row="0" Grid.RowSpan="3" BackgroundColor="#DD000011" IsVisible="False">
            <Border BackgroundColor="#1E1E3F"
                    Stroke="#FFCC00"
                    StrokeThickness="2"
                    Margin="20"
                    MaximumHeightRequest="650"
                    HorizontalOptions="Fill"
                    VerticalOptions="Center"
                    Padding="25">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="20"/>
                </Border.StrokeShape>

                <ScrollView>
                    <VerticalStackLayout Spacing="15">

                        <!-- Category + Point value + Skip -->
                        <Grid ColumnDefinitions="*, Auto">
                            <VerticalStackLayout Spacing="2">
                                <Label x:Name="ModalCategoryLabel" TextColor="White" FontSize="13" FontAttributes="Bold" Opacity="0.7"/>
                                <Label x:Name="ModalPointValueLabel" TextColor="#FFCC00" FontSize="22" FontAttributes="Bold"/>
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    x:Name="SkipButton"
                                    Text="Skip ⏭"
                                    TextColor="White"
                                    Clicked="OnSkipClicked"
                                    BackgroundColor="#0F0F2D"
                                    FontSize="13"
                                    FontAttributes="Bold"
                                    CornerRadius="20"
                                    Padding="15,8"
                                    VerticalOptions="Start"/>
                        </Grid>

                        <!-- Question -->
                        <Border BackgroundColor="#0F0F2D" Padding="15" MinimumHeightRequest="90">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14"/>
                            </Border.StrokeShape>
                            <Label x:Name="ModalClueLabel"
                                   TextColor="White"
                                   FontSize="18"
                                   HorizontalTextAlignment="Center"
                                   LineBreakMode="WordWrap"/>
                        </Border>

                        <Label x:Name="ModalAnswerLabel"
                               Text="Answer Text"
                               TextColor="#FFCC00"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               LineBreakMode="WordWrap"
                               IsVisible="False"/>

                        <!-- Timer -->
                        <ProgressBar x:Name="TimerBar" Progress="1" ProgressColor="#4CD964" HeightRequest="10" IsVisible="False"/>

                        <Label x:Name="TimerLabel"
                               Text=""
                               TextColor="#4CD964"
                               FontSize="16"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"
                               IsVisible="False"/>

                        <!-- WHO KNOWS THE ANSWER -->
                        <Label x:Name="WhoKnowsLabel"
                               Text="WHO KNOWS THE ANSWER?"
                               TextColor="#FFCC00"
                               FontSize="13"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>

                        <!-- Buzz-in Grid -->
                        <Grid x:Name="BuzzInGrid"
                              RowDefinitions="Auto, Auto"
                              ColumnDefinitions="*, *"
                              RowSpacing="10"
                              ColumnSpacing="10"/>

                        <!-- Show Answer -->
                        <Grid x:Name="PreAnswerButtonRow" IsVisible="False">
                            <Button Text="SHOW ANSWER"
                                    Clicked="OnShowAnswerClicked"
                                    BackgroundColor="#FFCC00"
                                    TextColor="#0F0F2D"
                                    CornerRadius="16"
                                    FontSize="17"
                                    FontAttributes="Bold"
                                    HeightRequest="55"
                                    HorizontalOptions="Fill"/>
                        </Grid>
                        <!-- Correct/Incorrect -->
                        <HorizontalStackLayout x:Name="PostAnswerButtonRow" Spacing="15" HorizontalOptions="Center" IsVisible="False">
                            <Button Text="CORRECT" Clicked="OnCorrectClicked" BackgroundColor="#2ECC71" TextColor="White" CornerRadius="14" FontAttributes="Bold" WidthRequest="130"/>
                            <Button Text="INCORRECT" Clicked="OnIncorrectClicked" BackgroundColor="#E74C3C" TextColor="White" CornerRadius="14" FontAttributes="Bold" WidthRequest="130"/>
                        </HorizontalStackLayout>

                        <!-- Proceed (timeout case) -->
                        <Button x:Name="ProceedButton"
                                Text="TIME'S UP — PROCEED"
                                Clicked="OnProceedClicked"
                                BackgroundColor="#3A5C8C"
                                TextColor="White"
                                CornerRadius="16"
                                FontSize="16"
                                FontAttributes="Bold"
                                HeightRequest="55"
                                HorizontalOptions="Fill"
                                IsVisible="False"/>
                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

        <!-- BOARD END MODAL (leaderboard / final scoreboard) -->
        <Grid x:Name="BoardEndModal" Grid.Row="0" Grid.RowSpan="3" BackgroundColor="#DD000011" IsVisible="False">
            <Border BackgroundColor="#0B1220"
                    Stroke="#1E2A44"
                    StrokeThickness="1"
                    Margin="20"
                    MaximumHeightRequest="700"
                    HorizontalOptions="Fill"
                    VerticalOptions="Center"
                    Padding="25">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24"/>
                </Border.StrokeShape>

                <ScrollView>
                    <VerticalStackLayout Spacing="18">

                        <Label Text="GAME OVER"
                               TextColor="#FFD700"
                               FontSize="34"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center"/>

                        <Label Text="FINAL SCORES"
                               TextColor="#7E91AA"
                               FontSize="13"
                               FontAttributes="Bold"
                               CharacterSpacing="1"
                               HorizontalTextAlignment="Center"/>

                        <!-- Winner spotlight card -->
                        <Border BackgroundColor="#D4AF37"
                                Stroke="#FFD700"
                                StrokeThickness="2"
                                Padding="20">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20"/>
                            </Border.StrokeShape>
                            <VerticalStackLayout x:Name="WinnerCardHost" Spacing="4" HorizontalOptions="Center"/>
                        </Border>

                        <!-- Ranked list (2nd place onward) -->
                        <VerticalStackLayout x:Name="BoardEndContentHost" Spacing="10"/>

                        <Button Text="Play Again"
                                Clicked="OnBoardEndActionClicked"
                                BackgroundColor="#FFD200"
                                TextColor="#0F0F2D"
                                CornerRadius="24"
                                FontSize="17"
                                FontAttributes="Bold"
                                HeightRequest="60"
                                HorizontalOptions="Fill"/>

                    </VerticalStackLayout>
                </ScrollView>
            </Border>
        </Grid>

    </Grid>
</ContentPage>