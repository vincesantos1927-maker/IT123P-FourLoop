<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="jeo_ano_ba.MainPage"
             Title="Jeopardy"
             BackgroundColor="#0F0F2D">

    <Grid RowDefinitions="Auto, *, Auto" Padding="20" RowSpacing="15" ColumnSpacing="15">

        <HorizontalStackLayout Grid.Row="0" Spacing="15" HorizontalOptions="End">
            <Button Text="End Game"
            Clicked="OnEndGameClicked"
            BackgroundColor="#333333"
            TextColor="White"
            FontAttributes="Bold"/>
        </HorizontalStackLayout>
        <Grid Grid.Row="1" ColumnDefinitions="0, *">

            <VerticalStackLayout Grid.Column="0" Spacing="10" Padding="5" IsVisible="False">
                <Label Text="Games In Database:" TextColor="Gray" FontAttributes="Bold"/>
                <ListView x:Name="GamesListView" ItemSelected="OnGameSelected" BackgroundColor="#1E1E3F">
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <TextCell Text="{Binding Name}" TextColor="White"/>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </VerticalStackLayout>

            <ScrollView Grid.Column="1" Orientation="Horizontal" HorizontalOptions="Center">
                <HorizontalStackLayout x:Name="ProxyBoardGrid" Spacing="10" Padding="10">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Spacing="8" WidthRequest="140">
                                <Border BackgroundColor="#060CE9" Stroke="White" Padding="5" HeightRequest="60">
                                    <Label Text="{Binding Name}" TextColor="White" FontAttributes="Bold" HorizontalTextAlignment="Center" FontSize="12"/>
                                </Border>
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding Clues}" Spacing="6">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate>
                                            <Button Text="{Binding PointValue, StringFormat='${0}'}" Clicked="OnClueTileClicked" CommandParameter="{Binding .}" HeightRequest="55" BackgroundColor="#060CE9" TextColor="#FFCC00">
                                                <Button.Triggers>
                                                    <DataTrigger TargetType="Button" Binding="{Binding IsCompleted}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="#111133"/>
                                                        <Setter Property="Text" Value="✖"/>
                                                        <Setter Property="IsEnabled" Value="False"/>
                                                    </DataTrigger>
                                                </Button.Triggers>
                                            </Button>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </HorizontalStackLayout>
            </ScrollView>
        </Grid>
        <Grid x:Name="EvaluationModal" Grid.Row="0" Grid.RowSpan="3" BackgroundColor="#F0000011" IsVisible="False">
            <Border BackgroundColor="#060CE9" Stroke="White" StrokeThickness="3" WidthRequest="450" HeightRequest="320" HorizontalOptions="Center" VerticalOptions="Center" Padding="20">
                <VerticalStackLayout Spacing="15" VerticalOptions="Center">
                    <Label x:Name="ModalClueLabel" 
                           TextColor="White" 
                           FontSize="20" 
                           HorizontalTextAlignment="Center" 
                           LineBreakMode="WordWrap"/>

                    <Label x:Name="TimerLabel"
                           Text=""
                           TextColor="#FFCC00"
                           FontSize="22"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="Center"
                           IsVisible="False"/>

                    <Label x:Name="ModalAnswerLabel" Text="Answer Text" TextColor="#FFCC00" FontSize="18" FontAttributes="Bold" HorizontalTextAlignment="Center" LineBreakMode="WordWrap" IsVisible="False"/>

                    <HorizontalStackLayout x:Name="PreAnswerButtonRow"
                       Spacing="15"
                       HorizontalOptions="Center"
                       IsVisible="False">
                        <Button Text="SHOW ANSWER"
                        Clicked="OnShowAnswerClicked"
                        BackgroundColor="#FFCC00"
                        TextColor="Black"
                        FontAttributes="Bold"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout x:Name="PostAnswerButtonRow" Spacing="15" HorizontalOptions="Center" IsVisible="False">
                        <Button Text="CORRECT" Clicked="OnCorrectClicked" BackgroundColor="Green" TextColor="White" FontAttributes="Bold"/>
                        <Button Text="INCORRECT" Clicked="OnIncorrectClicked" BackgroundColor="Red" TextColor="White" FontAttributes="Bold"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
